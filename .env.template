# --- API Keys ---
YOUTUBE_API_KEY=your_youtube_api_key_here

# LLM Configuration (supports any LiteLLM compatible model)
# Format: provider/model_name (e.g., groq/llama-3.3-70b-versatile, gemini/gemini-1.5-pro)
LLM_MODEL=groq/llama-3.3-70b-versatile
LLM_API_KEY=your_llm_api_key_here
# LLM_API_BASE=http://localhost:1234/v1  # Uncomment for local LLMs like LM Studio

# Fallback LLM (optional, used if primary fails)
# FALLBACK_LLM_API_KEY=not-needed
# FALLBACK_LLM_API_BASE=http://localhost:11434/v1

# Advanced LLM Settings (Optional)
# LLM_MAX_TOKENS=2000
# LLM_EXTRA_PARAMS={"include_reasoning": false, "temperature": 0}

# --- App Settings ---
LOG_LEVEL=INFO
MAX_VIDEO_DURATION_SEC=600
TRANSLATION_BATCH_SIZE=25

# --- Paths ---
# LOG_DIR=logs
# DOWNLOAD_DIR=/Volumes/NAS/MezamashiLingo  # Your NAS path
# FALLBACK_DOWNLOAD_DIR=downloads          # Local fallback
# VOCALS_DIR=downloads/vocals
# CHANNELS_FILE=channels.json
# HISTORY_FILE=history.json
# SELECTION_FILE=latest_selection.json
